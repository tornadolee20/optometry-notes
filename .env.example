# OpenClaw / Jarvis Environment Configuration Example
# 改名為 .env 並填入你的金鑰

# --- 基礎配置 ---
# OpenClaw 偵測到的通訊平台設定 (例如 Telegram)
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- 大腦配置 (LLM) ---
# 建議使用 Anthropic Claude 或 Google Gemini
ANTHROPIC_API_KEY=your_anthropic_key
GOOGLE_API_KEY=your_gemini_key

# --- 強化與同步 ---
# 用於與大叔 (ANTIGRAVITY) 的記憶同步與反思機制
EVOLUTION_MODE=true
FORTRESS_BACKUP_PATH=./backup

# --- 警告 ---
# 絕對不要將含有真實金鑰的 .env 檔案上傳至任何公開的 Git 倉庫！
