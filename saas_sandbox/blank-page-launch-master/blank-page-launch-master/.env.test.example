# 測試環境配置範例
# 複製此文件為 .env.test 並填入你的測試數據庫資訊

# 測試數據庫 Supabase 配置（用於集成測試）
TEST_SUPABASE_URL=https://your-test-project.supabase.co
TEST_SUPABASE_ANON_KEY=your-test-anon-key
TEST_SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-key

# 測試用戶資訊（用於 E2E 測試）
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=testpassword123
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=adminpassword123

# API 測試配置
TEST_API_BASE_URL=http://localhost:3000
TEST_WEBHOOK_SECRET=your-test-webhook-secret

# 第三方服務測試 keys（通常使用 sandbox 環境）
TEST_STRIPE_PUBLISHABLE_KEY=pk_test_...
TEST_STRIPE_SECRET_KEY=sk_test_...

# 其他測試配置
TEST_TIMEOUT=30000
TEST_RETRY_COUNT=3